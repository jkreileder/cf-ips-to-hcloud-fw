{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "automergeStrategy": "squash",
    "customManagers": [
        {
            "customType": "regex",
            "datasourceTemplate": "docker",
            "description": "Keep docker/scout-sbom-indexer current - it is passed as the sbom generator input to docker/build-push-action, so no standard manager sees it.",
            "managerFilePatterns": [
                ".github/workflows/docker.yaml"
            ],
            "matchStrings": [
                "generator=(?<depName>docker/scout-sbom-indexer):(?<currentValue>[^@'\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)"
            ]
        },
        {
            "customType": "regex",
            "datasourceTemplate": "docker",
            "description": "Pin tonistiigi/binfmt (setup-qemu-action image input) by version + digest.",
            "managerFilePatterns": [
                ".github/workflows/docker.yaml"
            ],
            "matchStrings": [
                "image: (?<depName>tonistiigi/binfmt):(?<currentValue>qemu-v[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)"
            ],
            "versioningTemplate": "regex:^qemu-v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
        },
        {
            "customType": "regex",
            "datasourceTemplate": "docker",
            "description": "Pin moby/buildkit (setup-buildx-action driver image) by version + digest.",
            "managerFilePatterns": [
                ".github/workflows/docker.yaml"
            ],
            "matchStrings": [
                "image=(?<depName>moby/buildkit):(?<currentValue>v[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)"
            ]
        }
    ],
    "extends": [
        "config:best-practices",
        ":gitSignOff",
        "schedule:earlyMondays",
        "schedule:automergeDaily",
        ":enablePreCommit"
    ],
    "internalChecksFilter": "strict",
    "labels": [
        "dependencies"
    ],
    "lockFileMaintenance": {
        "automerge": true
    },
    "minimumReleaseAge": "3 days",
    "osvVulnerabilityAlerts": true,
    "packageRules": [
        {
            "description": "SLSA generators run as reusable workflows verified by tag ref - never pin to a digest.",
            "matchDepNames": [
                "slsa-framework/slsa-github-generator"
            ],
            "pinDigests": false
        },
        {
            "description": "Group GitHub Actions minor/patch into one PR; majors get their own PR.",
            "groupName": "github-actions",
            "matchManagers": [
                "github-actions"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ]
        },
        {
            "description": "Group container/image minor/patch into one PR; majors get their own PR.",
            "groupName": "docker",
            "matchManagers": [
                "dockerfile",
                "custom.regex"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ]
        },
        {
            "description": "Group pre-commit hook minor/patch into one PR; majors get their own PR.",
            "groupName": "pre-commit",
            "matchManagers": [
                "pre-commit"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ]
        },
        {
            "automerge": true,
            "description": "Default for pep621: treat as dev tooling - group minor/patch and automerge.",
            "groupName": "uv (dev)",
            "matchManagers": [
                "pep621"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ]
        },
        {
            "automerge": false,
            "description": "Runtime application dependencies: grouped, manual review.",
            "groupName": "uv (runtime)",
            "matchDepTypes": [
                "project.dependencies"
            ],
            "matchManagers": [
                "pep621"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ]
        },
        {
            "automerge": false,
            "description": "Build backend (uv_build): its own PR, manual - build-system changes can affect packaging.",
            "groupName": "uv (build-system)",
            "matchDepTypes": [
                "build-system.requires"
            ],
            "matchManagers": [
                "pep621"
            ]
        },
        {
            "description": "Keep uv together in one PR (the setup-uv input, the Docker uv image, and the uv-pre-commit hook).",
            "groupName": "uv",
            "matchPackageNames": [
                "astral-sh/uv",
                "astral-sh/uv-pre-commit",
                "ghcr.io/astral-sh/uv"
            ]
        },
        {
            "automerge": true,
            "description": "Automerge digest-only refreshes and initial digest pins (actions + images).",
            "groupName": "digests",
            "matchUpdateTypes": [
                "digest",
                "pin"
            ]
        }
    ],
    "semanticCommits": "enabled",
    "timezone": "Europe/Berlin",
    "vulnerabilityAlerts": {
        "labels": [
            "security"
        ]
    }
}
